{
  "expo": {
    "name": "Yuvam",
    "slug": "yuvam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/yuvam.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/yuvam.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F4EF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yuvam.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/yuvam.png",
        "backgroundColor": "#F8F4EF"
      },
      "package": "com.yuvam.mobile",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Çeyiz uygulaması fotoğraf galerinize erişmek istiyor.",
          "cameraPermission": "Çeyiz uygulaması kamera kullanmak istiyor."
        }
      ],
      [
        "onesignal-expo-plugin",
        {
          "mode": "production",
          "largeIcons": [
            "./assets/yuvam.png"
          ]
        }
      ],
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "54b7473b-a382-430b-b766-fd1b6c41b60b"
      }
    },
    "owner": "mrpurposeless53"
  }
}
